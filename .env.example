# ─── Côté client (exposées dans le bundle Vite) ───
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_STRIPE_PUBLIC_KEY=

# ─── Côté serveur (Vercel env vars, jamais dans le bundle client) ───
SUPABASE_SERVICE_ROLE_KEY=
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Secret utilisé pour signer les tokens de reprise du formulaire d'intake
# (chaîne aléatoire longue). Si absent, le SERVICE_ROLE_KEY est utilisé en fallback.
RESUME_TOKEN_SECRET=

# Envoi des courriels de reprise (Session 2A)
RESEND_API_KEY=
RESEND_FROM="5PennyAi <no-reply@5pennyai.com>"

# URL publique utilisée pour construire les liens envoyés par courriel.
# Ex: https://5pennyai.com ou http://localhost:5173 en local.
PUBLIC_BASE_URL=http://localhost:5173

# Secret exigé en header Authorization par les endpoints /api/cron/*.
# Vercel Cron envoie automatiquement `Bearer $CRON_SECRET` quand la variable
# est définie sur le projet. Générer une chaîne aléatoire longue.
CRON_SECRET=

# Secret pour les appels internes (orchestrateur → send-completion-emails).
# Si non défini, CRON_SECRET est utilisé en fallback.
INTERNAL_HOOK_SECRET=

# Secret pour /api/admin/* (endpoints de suivi, ex. /api/admin/costs).
# Si non défini, CRON_SECRET est utilisé en fallback.
ADMIN_API_SECRET=

# ─── Session 2B — pipeline d'audit ───

# Destinataire du courriel admin "Nouvel audit à réviser" (Christian).
ADMIN_EMAIL=christian@5pennyai.com
ADMIN_NAME="Christian Couillard"

# Expéditeur du courriel client (personnel, répondable). Si non défini,
# RESEND_FROM (no-reply@...) est utilisé — moins chaleureux.
RESEND_FROM_CLIENT="Christian Couillard <christian@5pennyai.com>"

# Debug : si "true", logge la réponse brute de Claude avant validation Zod
# pour chaque skill. Utile pour diagnostiquer une dérive de schéma. Laisser
# vide ou "false" en production.
DEBUG_CLAUDE_RESPONSES=

# ─── Session 2C — auth admin ───

# Mot de passe d'accès à /admin/* (interface de révision des audits).
# Choisir une chaîne longue, jamais commit. Christian est le seul admin.
ADMIN_PASSWORD=

# Secret pour signer le cookie de session admin (HMAC-SHA256).
# Minimum 32 caractères, distinct de tous les autres secrets.
ADMIN_SESSION_SECRET=

# Durée de vie d'une session admin, en heures. Défaut : 12.
ADMIN_SESSION_DURATION_HOURS=12

# Secret pour signer les tokens de rapport public (HMAC-SHA256, 90 jours).
# Si absent, fallback sur RESUME_TOKEN_SECRET puis SUPABASE_SERVICE_ROLE_KEY.
# Recommandé : chaîne aléatoire dédiée (48+ caractères).
REPORT_TOKEN_SECRET=
