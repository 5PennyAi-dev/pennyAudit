# ─── Côté client (exposées dans le bundle Vite) ───
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_STRIPE_PUBLIC_KEY=

# ─── Côté serveur (Vercel env vars, jamais dans le bundle client) ───
SUPABASE_SERVICE_ROLE_KEY=
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Secret utilisé pour signer les tokens de reprise du formulaire d'intake
# (chaîne aléatoire longue). Si absent, le SERVICE_ROLE_KEY est utilisé en fallback.
RESUME_TOKEN_SECRET=

# Envoi des courriels de reprise (Session 2A)
RESEND_API_KEY=
RESEND_FROM="5PennyAi <no-reply@5pennyai.com>"

# URL publique utilisée pour construire les liens envoyés par courriel.
# Ex: https://5pennyai.com ou http://localhost:5173 en local.
PUBLIC_BASE_URL=http://localhost:5173
